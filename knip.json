{
  "$schema": "https://unpkg.com/knip@next/schema.json",
  "entry": ["src/main.ts", "src/polyfills.ts"],
  "project": ["src/**/*.ts"],
  "ignore": ["**/*.spec.ts", "src/test.ts", "src/environments/*.ts"],
  "ignoreDependencies": [
    "@angular/localize",
    "@fontsource/*",
    "web-animations-js",
    "classlist.js"
  ],
  "angular": {
    "entry": ["src/main.ts"]
  }
}
