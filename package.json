{
  "name": "random-gifs",
  "version": "1.0.0",
  "scripts": {
    "start": "ng serve -o --port 65000",
    "start-prod": "ng serve -o --configuration production --port 65000",
    "build": "ng build --configuration production",
    "test": "ng test",
    "e2e": "ng e2e",
    "lint": "ng lint random-gifs --typeCheck=true --tslintConfig=tslint.json --tsConfig=tsconfig.json",
    "lint-fix": "ng lint random-gifs --typeCheck=true --tslintConfig=tslint.json --tsConfig=tsconfig.json --fix",
    "tslint-fix": "tslint --project tsconfig.json src/**/*.ts --fix",
    "stylelint": "stylelint src/**/*.scss",
    "stylelint-fix": "stylelint src/**/*.scss --fix",
    "generate-icons": "svg-generator"
  },
  "dependencies": {
    "@angular/animations": "^20.3.18",
    "@angular/common": "^20.3.18",
    "@angular/compiler": "^20.3.18",
    "@angular/core": "^20.3.18",
    "@angular/forms": "^20.3.18",
    "@angular/localize": "^20.3.18",
    "@angular/platform-browser": "^20.3.18",
    "@angular/platform-browser-dynamic": "^20.3.18",
    "@angular/router": "^20.3.18",
    "@fontsource/montserrat": "^4.2.2",
    "@fontsource/roboto": "^4.2.3",
    "@mdi/svg": "^5.9.55",
    "@ngneat/svg-icon": "^4.1.4",
    "ngx-webstorage": "^10.0.1",
    "rxjs": "~6.6.6",
    "tslib": "^2.1.0",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.3.21",
    "@angular/cli": "^20.3.21",
    "@angular/compiler-cli": "^20.3.18",
    "@ngneat/svg-generator": "^2.0.0",
    "@types/jasmine": "~3.6.7",
    "@types/node": "^14.14.35",
    "angular-tslint-rules": "^1.20.4",
    "autoprefixer": "^10.2.5",
    "codelyzer": "^6.0.1",
    "jasmine-core": "~3.7.1",
    "jasmine-spec-reporter": "~6.0.0",
    "karma": "^6.4.4",
    "karma-chrome-launcher": "~3.1.0",
    "karma-coverage": "~2.0.3",
    "karma-jasmine": "~4.0.1",
    "karma-jasmine-html-reporter": "^1.5.4",
    "npm": "^7.7.0",
    "postcss": "^8.5.6",
    "protractor": "~7.0.0",
    "stylelint": "^13.12.0",
    "stylelint-config-recommended": "^4.0.0",
    "stylelint-scss": "^3.19.0",
    "tailwindcss": "^2.1.1",
    "ts-node": "~9.1.1",
    "tslint": "~6.1.3",
    "tslint-eslint-rules": "^5.4.0",
    "typescript": "5.8.3"
  },
  "svgGenerator": {
    "outputPath": "./src/app/svg",
    "prefix": "app",
    "srcPath": "./src/assets/svg",
    "svgoConfig": {
      "plugins": [
        {
          "removeDimensions": true,
          "cleanupAttrs": true
        }
      ]
    }
  }
}